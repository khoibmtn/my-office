{
  "manifest_version": 3,
  "name": "My Office - QLVB Helper",
  "version": "1.0.0",
  "description": "Tự động lấy văn bản từ qlvb.hpnet.vn và gửi đến My Office",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://qlvb.hpnet.vn/*",
    "http://qlvb.hpnet.vn/*",
    "http://localhost:*/*",
    "https://*.vercel.app/*",
    "https://www.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://qlvb.hpnet.vn/*", "http://qlvb.hpnet.vn/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*", "https://*.vercel.app/*"],
      "js": ["token-sync.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
